{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "hooks/ticket-refiner-router.py",
        "matcher": "UserPromptSubmit",
        "timeout": 3,
        "failClosed": false
      },
      {
        "command": "hooks/pipeline-gate-router.py",
        "matcher": "UserPromptSubmit",
        "timeout": 3,
        "failClosed": false
      }
    ],
    "afterFileEdit": [
      {
        "command": "hooks/writer-guard.py",
        "timeout": 3,
        "failClosed": true
      },
      {
        "command": "hooks/spec-archive.py",
        "timeout": 5,
        "failClosed": false
      }
    ]
  }
}
